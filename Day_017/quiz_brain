import random
class Brain:
    def __init__(self,q_list):
        self.question_number = 0
        self.question_list = q_list
        self.score = 0

    def next_question(self):
        while True:
            question = self.question_list[self.question_number]
            ques = random.choice(self.question_list)
            self.question_number += 1
            answer = input(f"Q. {self.question_number}: {ques.question} (True/False): ").lower()
            if answer == ques.answer.lower():
                print("You were right, Correct answer was:", ques.answer)
                self.score += 1
            else:
                print("You were wrong, Correct answer was:", ques.answer)
            print(f"Current score: {self.score}/{self.question_number}\n\n")
            if self.question_number == 10:

                print("You get the final score of:", self.score)
                break
